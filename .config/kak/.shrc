PS1=''
PS2=''
PS3=''
PS4=''

export EDITOR=kakedit
export VISUAL=kakedit

alias la='ls -A'
alias ll='ls -lh'
alias xrm='doas xbps-remove'
alias xs='xbps-query'
alias xss='xbps-query -s'
alias xf='xbps-query -f'
alias xrf='xbps-query -Rf'
alias grc='gh repo clone'
alias chx='chmod +x'
alias d='doas'
alias usv='env SVDIR=$HOME/.service sv'
alias sv='doas sv'
alias dotfiles='/bin/git --git-dir=$HOME/devel/wip/dotfiles/ --work-tree=$HOME'
alias winewl='env -u DISPLAY ~/.local/wine/bin/wine'
alias bat='cat /sys/class/power_supply/BAT0/capacity'
alias fc=footclient
alias idf=~/devel/sdk/esp-idf-v6.0.1/tools/idf.py
alias idfexp='IDF_PATH=~/devel/sdk/esp-idf-v6.0.1 IDF_PATH_FORCE=1 . ~/devel/sdk/esp-idf-v6.0.1/export.sh'
alias zigesp='~/.zig/zig-relsafe-x86_64-linux-musl-baseline/zig'
alias za='zoxide add >/dev/null 2>&1'

