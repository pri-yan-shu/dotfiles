t() {
	if cd "$1"; then
        bufname=$$
        {
        	kak_cmd_buf $bufname "sh-cd '$PWD' '${PWD##*/} '"
        	kak_cmd_client modeline
        } | kak_cmd
		zoxide add "$PWD" >/dev/null 2>&1
		return 0
	else
		return 1
	fi
}


md() {
	mkdir -p "$@" && t "$@"
}

kak_cmd() {
    kak -p $kak_session
}

kak_cmd_client() {
    printf %s\\n "eval -client $kak_client %{$*}"
}

kak_cmd_buf() {
    buf=$1
    shift
    printf %s\\n "eval -buffer $buf %{$*}"
}

watch() {
    cmd=$1
    shift
    inotifywait -m -e close_write --format '%w%f' $@ | while read -r file; do
        eval "$cmd"
    done
}

